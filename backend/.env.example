MONGO_URI=mongodb://localhost:27017
DB_NAME=notes_platform
MONGO_SERVER_SELECTION_TIMEOUT_MS=1500

JWT_SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=lax
APP_ENV=development
REDIS_URL=redis://localhost:6379/0
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CACHE_DEFAULT_TTL_SECONDS=60
NOTE_PUBLISH_POINTS=15
INITIAL_WALLET_POINTS=200
TOP_CONTRIBUTOR_BONUS_POINTS=100
POINTS_SELLER_REWARD_PERCENT=80
PAYMENT_PENDING_TTL_SECONDS=1800
LOG_JSON=true
SLOW_QUERY_THRESHOLD_MS=250
AI_JOB_MAX_ATTEMPTS=3
ENABLE_SECURITY_HEADERS=true

# Email Verification (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Notes Market <yourgmail@gmail.com>

# Hybrid moderation AI
# auto = Gemini first (if GEMINI_API_KEY set), then Ollama, then rules
# gemini = Gemini only
# ollama = local model only
# rules = no model calls, deterministic validation
MODERATION_AI_MODE=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3.1:8b
