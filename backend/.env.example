MONGO_URI=mongodb://localhost:27017
DB_NAME=notes_platform
MONGO_SERVER_SELECTION_TIMEOUT_MS=1500

JWT_SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=lax
APP_ENV=development
REDIS_URL=redis://localhost:6379/0
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
CACHE_DEFAULT_TTL_SECONDS=60
LOG_JSON=true
SLOW_QUERY_THRESHOLD_MS=250
AI_JOB_MAX_ATTEMPTS=3
ENABLE_SECURITY_HEADERS=true

# Email Verification (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Notes Market <yourgmail@gmail.com>

# Hybrid moderation AI (free-first)
# auto = try local Ollama first, fallback to rules
# ollama = local model only
# rules = no model calls, deterministic validation
MODERATION_AI_MODE=rules
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3.1:8b
